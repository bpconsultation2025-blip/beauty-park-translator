# ============================================================
# 뷰티파크 번역 시스템 환경변수 설정
# ============================================================
# 이 파일을 복사해서 '.env.local' 이름으로 저장한 후 값을 채워주세요.
# Vercel 배포 시에는 Vercel 대시보드의 Settings → Environment Variables에 동일하게 입력하세요.

# ---- Anthropic API ----
# https://console.anthropic.com 에서 발급받은 API 키
ANTHROPIC_API_KEY=sk-ant-api03-여기에_붙여넣기

# ---- Firebase (공개 가능한 클라이언트 설정) ----
# Firebase Console → 프로젝트 설정 → 일반 → 웹앱에서 복사
NEXT_PUBLIC_FIREBASE_API_KEY=여기에_붙여넣기
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=xxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=xxx
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=xxx.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# ---- 보안 시크릿 (아무 긴 문자열) ----
# 쿠키 서명용. 영문+숫자 32자 이상 추천.
# 터미널에서 `openssl rand -hex 32` 또는 아무거나 길게 입력.
AUTH_SECRET=변경해주세요_여기에_길고_복잡한_문자열_입력_32자_이상
